{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "objectWrap": "preserve",
  "endOfLine": "lf",
  "sortImports": {
    "groups": [["builtin", "external"], "parent", ["index", "sibling"]],
    "newlinesBetween": true,
    "order": "asc",
    "ignoreCase": true
  },
  "ignorePatterns": ["node_modules", "dist", "pnpm-lock.yaml"]
}
